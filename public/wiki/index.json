  "modules": [
    {
      "id": "module.kingsport-city-in-the-mists",
      "displayName": "永恒恶意",
      "aliases": [
        "金斯波特迷雾之城",
        "永恒恶意",
        "Everlasting Malice"
      ],
      "summary": "官方模组密斯卡托尼克河流域新传系列之五。在本篇中，调查员需要解开神秘的连环失明事件背后的恐怖真相。（反派很强）",
      "ruleSystem": "COC7",
      "playerCount": "34-6",
      "duration": "6-10h",
      "collection": "密斯卡托尼克河流域新传",
      "description": "「三周前，报道居民西蒙·麦当劳患上神秘疾病。六天后，伯纳德·怀特亦遭同样厄运。此后类似情况接连出现，报道令镇民不安；警局与政府尽力安抚。」\n「等待你们的会是……什么呢？」\n\n【简介】\n官方模组密斯卡托尼克河流域新传系列之五。在本篇中，调查员需要解开神秘的连环失明事件背后的恐怖真相。（反派很强）\n\n【推荐语】\n官方模组系列之五，延续了官模的高质量。本作之中调查员们会遇到一个劲敌，作为幕后黑手十分狡猾并且会给调查员们抛出不少的烟雾弹和陷阱。如果守密人不通过某些手段放水的话，调查员很容易在途中遭到团灭。就算调查员闯过重重阻碍，甚至还可能遇见更坏的情况。总而言之，不剧透的话就只能说到这里了，是一个非常值得一跑的官模。",
      "tags": [
        "1920s",
        "近代",
        "美洲"
      ]
    },
    {
      "id": "module.profile.night-battle",
      "displayName": "夜战",
      "aliases": [
        "夜战"
      ],
      "summary": "官方模组密斯卡托尼克河流域新传系列之六。在本篇中，调查员误入一名创伤老兵的噩梦世界，他们能否在阻止噩梦扩散的同时，将梦者从无尽的痛苦中拯救出来呢…（一个可以正大光明玩迫击炮的官模！）",
      "ruleSystem": "COC7",
      "playerCount": "4-6",
      "duration": "5-8h",
      "collection": "密斯卡托尼克河流域新传",
      "description": "1918西线战壕，步枪上膛，炮火将至。每次建卡都有人问\"KP我能点炮术吗\"，每次答案都是\"你点了也没地方用\"。这次不一样。点吧，都点吧，管够。。 \n\n【简介】\n官方模组密斯卡托尼克河流域新传系列之六。在本篇中，调查员误入一名创伤老兵的噩梦世界，他们能否在阻止噩梦扩散的同时，将梦者从无尽的痛苦中拯救出来呢…（一个可以正大光明玩迫击炮的官模！）\n\n【推荐语】\n如果认为官模都是上个世纪的线性美式模组的话，《夜战》这份模组一定会带给你不一样的体验，从给玩家带来心理阴影的方面，甚至不输大部分的日系模组……当然会更硬核一些。《夜战》的主要背景故事是一战，而对于远离战争的现代人来说，通过直面战争的方式体验这份魔幻现实主义的模组，更能珍惜当下来之不易的和平年代，不至于费拉不堪。从游玩体验上来说，模组以双线并行的方式开展故事，其主线会更偏向于只给材料，需要守密人自己烹饪的沙盒，而副线则是一个完整而简短的线性调查故事，较容易把握。总而言之，模组的题材可能会劝退不少玩家，但不妨碍这是近些时间创意高分的好模组。",
      "tags": [
        "1920s",
        "战争",
        "枪战",
        "近代",
        "美洲"
      ]
    },
    {
      "id": "module.miskatonic.newtales.midnight-web",
      "displayName": "午夜迷网",
      "aliases": [
        "午夜迷网"
      ],
      "summary": "官方模组密斯卡托尼克谷地新传系列之一。调查员被一封请柬带到瓦尔加伯爵夫人的派对，见证虚荣幻象下的毁灭。",
      "ruleSystem": "COC7",
      "playerCount": "2-5人",
      "duration": "4-8时",
      "collection": "密斯卡托尼克河流域新传",
      "description": "【简介】\n官方模组密斯卡托尼克谷地新传系列之一，和旧传以及阿卡姆扩展书中的自带模组一起构成了一个庞大的阿卡姆世界观，值得尝试。\n在本篇中，调查员被一封请柬带到了瓦尔加伯爵夫人举办的派对中，并将见证一个于虚荣幻象中迷失自我的可怜女人，为了维持虚伪的人设，在精神重压下走向毁灭的故事。\n本模组对PL的角色扮演以及与NPC的交流水平有较高的要求。\n\n【推荐语】\n相当原旨风味的官模，背景仍然是比较常见的1920阿卡姆。故事以一个不寻常的酒会出发，然后发生一系列需要调查的奇妙案件……因为不是线性结构的模组，所以需要KP在备团的时候做好线索梳理，但因为模组中的材料比以前的官模要丰富不少，所以倒也不用太担心需要填补细节的问题。模组前期的酒会部分占据了将近一半的篇幅，从带团节奏来讲可能会略显冗长，所以如果有需要的话，可以把前期不太重要的信息留在后期交待。",
      "tags": [
        "近代",
        "美洲"
      ]
    },
    {
      "id": "module.miskatonic.newtales.wasted-youth",
      "displayName": "虚度青春",
      "aliases": [
        "虚度青春"
      ],
      "summary": "官方模组密斯卡托尼克河流域新传系列之二。一系列少年犯罪将调查员卷入其中，最终演变成与时间的赛跑。",
      "ruleSystem": "COC7",
      "playerCount": "2-6人",
      "duration": "6-12时",
      "collection": "密斯卡托尼克河流域新传",
      "description": "【简介】\n官方模组密斯卡托尼克河流域新传系列之二。在本篇中，一系列莫名的少年犯罪将调查员卷入其中，最终演变成一场与时间的赛跑。调查员能否赶在扎洛索斯完成他那邪恶仪式前，挽救诸多儿童的生命？\n警告：模组中含有大量伤害儿童的情节，虽然程度不一定比早前的羊妈妈模组更重，但总归是有的。\n\n【推荐语】\n这个模组采用两段式的写法，前半主要是松散的调查，后半是一段复杂的追踪。以我有限的了解，后半段的设置是比较罕见的剧情安排方式。题材是这个模组最大的亮点和敏感方面。剧情设置可能会对玩家造成从现实SC到血压拉满等不同debuff。",
      "tags": [
        "近代",
        "美洲"
      ]
    },
    {
      "id": "module.miskatonic.newtales.factory-haunt",
      "displayName": "工厂邪灵",
      "aliases": [
