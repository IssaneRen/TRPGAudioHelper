      { "label": "关联人物", "value": "莱纳" }
    ],
    "content": [
      { "type": "heading", "text": "地点概览" },
      {
        "type": "paragraph",
        "tokens": [
          { "type": "text", "text": "阿卡姆 Arkham 是 " },
          { "type": "ref", "entryId": "char.leina", "label": "莱纳" },
          { "type": "text", "text": " 退伍后定居的城市。相比于 " },
