{
  "id": "book.unaussprechlichen-kulten",
  "category": "magic-book",
  "displayName": "无名祭祀 Unaussprechlichen Kulten",
  "summary": "又称若干被删节的题名。它像一册从旅行箱、民俗笔记和审查版索引里拼出的教团残档。",
  "aliasNames": [
    "Unaussprechlichen Kulten",
    "Nameless Cults",
    "Black Book",
    "无名祭祀",
    "无以名状的祭祀",
    "黑书"
  ],
  "relatedEntryIds": [
