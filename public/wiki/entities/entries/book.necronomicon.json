    },
    {
      "label": "创作来源",
      "value": "H. P. Lovecraft"
    },
    {
      "label": "资料核对",
      "value": "HPL Archive / Britannica / Lovecraft Encyclopedia，2026-06-04"
    }
  ],
  "tags": [
    "洛氏世界观",
