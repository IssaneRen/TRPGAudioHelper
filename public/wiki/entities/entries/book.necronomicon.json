{
  "id": "book.necronomicon",
  "category": "magic-book",
  "displayName": "Necronomicon",
  "summary": "洛氏世界观中最有名的禁忌典籍之一。它更像一份被不断转译、删节、封存的危险目录，而不是可以安全查阅的普通书籍。",
  "aliasNames": [
    "Necronomicon",
    "死灵之书",
    "Al Azif",
    "Kitab al-Azif"
  ],
  "relatedEntryIds": [
    "book.book-of-eibon",
    "book.de-vermis-mysteriis",
    "book.unaussprechlichen-kulten"
  ],
  "facts": [
