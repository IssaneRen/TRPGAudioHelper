{
  "id": "book.book-of-eibon",
  "category": "magic-book",
  "displayName": "伊波恩之书 Book of Eibon",
  "summary": "一组来自海柏利亚传统的残卷与转译抄本。它读起来不像后世学术书，更像术士留下的旅行、献辞和危险边注。",
  "aliasNames": [
    "Book of Eibon",
    "The Book of Eibon",
    "Liber Ivonis",
    "Livre d'Eibon",
    "伊波恩之书",
    "艾邦之书"
  ],
