    },
    {
      "type": "paragraph",
      "tokens": [
        {
          "type": "text",
          "text": "阿卡姆 Arkham 是 "
        },
        {
          "type": "ref",
          "entryId": "char.leina",
          "label": "莱纳"
        },
        {
          "type": "text",
          "text": " 退伍后定居的城市。相比于 "
