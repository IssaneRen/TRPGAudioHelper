{
  "name": "trpg-lucius-helper",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "generate:wiki": "tsx scripts/generate-wiki-index.ts",
    "seed:coc-sheets": "tsx scripts/seed-coc-sheets.ts",
    "import:wiki-library": "tsx scripts/import-wiki-library-modules.ts",
    "generate:blog": "tsx scripts/generate-blog-index.ts",
    "predev": "pnpm generate:wiki && tsx scripts/generate-blog-index.ts",
    "dev": "vite",
    "prebuild": "pnpm generate:wiki && tsx scripts/generate-blog-index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "pixi-live2d-display": "0.5.0-beta",
    "pixi.js": "7.4.3",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.5.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "gray-matter": "^4.0.3",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.22.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.2"
  }
}
